<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="0dp"
    android:paddingEnd="0dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:fitsSystemWindows="false"
    android:background="@android:color/transparent">

    <!-- Header bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_close"
            android:contentDescription="Close"
            app:tint="?attr/primaryColor"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            style="@style/TextSectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/change_language" />
    </RelativeLayout>

    <!-- Main card containing list (high opacity dialog surface) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/rounded_dialog_surface"
        android:orientation="vertical"
        android:layout_marginBottom="12dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="14dp">

        <!-- NestedScrollView per la lista delle lingue -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/languageScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical"
            android:fadeScrollbars="false"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/languagePickerList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <!-- Buttons Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Apply Changes centered -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnApplyChanges"
                style="@style/TextSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_dialog_surface"
                android:paddingHorizontal="32dp"
                android:paddingVertical="12dp"
                android:drawableStart="@drawable/ic_check"
                android:drawablePadding="12dp"
                android:gravity="center"
                android:text="@string/apply_changes"
                app:drawableTint="?attr/primaryColor"
                android:clickable="false"
                android:focusable="false"
                android:alpha="0.4" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
