<?xml version="1.0" encoding="utf-8"?>
<!-- Drawer search-options popup: a rounded glass card with two toggle rows
     (Android settings / contacts), each showing a leading icon and a trailing
     check when enabled. Anchored to open leftwards from the tune button. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_dialog_surface"
    android:minWidth="248dp"
    android:orientation="vertical"
    android:paddingVertical="6dp">

    <LinearLayout
        android:id="@+id/optSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_sc_settings"
            app:tint="?attr/primaryColor" />

        <TextView
            android:id="@+id/optSettingsLabel"
            style="@style/TextSmall"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:text="@string/search_settings_category"
            android:textColor="?attr/primaryColor" />

        <ImageView
            android:id="@+id/optSettingsCheck"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="12dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_check"
            app:tint="?attr/primaryColor" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginHorizontal="12dp"
        android:background="@drawable/divider_light" />

    <LinearLayout
        android:id="@+id/optContacts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_sc_person"
            app:tint="?attr/primaryColor" />

        <TextView
            android:id="@+id/optContactsLabel"
            style="@style/TextSmall"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:text="@string/search_contacts_category"
            android:textColor="?attr/primaryColor" />

        <ImageView
            android:id="@+id/optContactsCheck"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="12dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_check"
            app:tint="?attr/primaryColor" />
    </LinearLayout>
</LinearLayout>
