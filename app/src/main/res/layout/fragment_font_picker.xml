<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="0dp"
    android:paddingEnd="0dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:fitsSystemWindows="false"
    android:background="@android:color/transparent">

    <!-- Header bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_close"
            android:contentDescription="Close"
            app:tint="?attr/primaryColor"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            style="@style/TextSectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/font" />
    </RelativeLayout>

    <!-- Card 1: Textbox in alto per preview del font (pannello a parte) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_dialog_surface"
        android:orientation="vertical"
        android:layout_marginBottom="12dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="14dp">

        <EditText
            android:id="@+id/etFontPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="12dp"
            android:text="The quick brown fox jumps over the lazy dog."
            android:textSize="18sp"
            android:textColor="?attr/primaryColor"
            android:textColorHint="#808080"
            android:background="@drawable/rounded_rect_shade_color_glass"
            android:inputType="textMultiLine|textNoSuggestions"
            android:lines="2"
            android:minLines="2"
            android:maxLines="2" />
    </LinearLayout>

    <!-- Card 2: Main card containing list (high opacity dialog surface) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/rounded_dialog_surface"
        android:orientation="vertical"
        android:layout_marginBottom="12dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="14dp">

        <!-- NestedScrollView per la lista dei font -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/fontScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical"
            android:fadeScrollbars="false"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/fontPickerList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <!-- Buttons Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Row 1: Add Custom Font & Remove Font -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/btnAddCustomFont"
                style="@style/TextSmall"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/rounded_dialog_surface"
                android:paddingHorizontal="16dp"
                android:drawableStart="@drawable/ic_font"
                android:drawablePadding="12dp"
                android:gravity="center_vertical"
                android:text="@string/add_custom_font"
                app:drawableTint="?attr/primaryColor"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnRemoveFont"
                style="@style/TextSmall"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/rounded_dialog_surface"
                android:paddingHorizontal="16dp"
                android:drawableStart="@drawable/ic_delete"
                android:drawablePadding="12dp"
                android:gravity="center_vertical"
                android:text="@string/remove_font"
                app:drawableTint="?attr/primaryColor"
                android:clickable="false"
                android:focusable="false"
                android:alpha="0.4"/>
        </LinearLayout>

        <!-- Row 2: Apply Changes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnApplyChanges"
                style="@style/TextSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_dialog_surface"
                android:paddingHorizontal="32dp"
                android:paddingVertical="12dp"
                android:drawableStart="@drawable/ic_check"
                android:drawablePadding="12dp"
                android:gravity="center"
                android:text="@string/apply_changes"
                app:drawableTint="?attr/primaryColor"
                android:clickable="false"
                android:focusable="false"
                android:alpha="0.4" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
