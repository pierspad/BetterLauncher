<?xml version="1.0" encoding="utf-8"?>
<!-- Generic message dialog: opaque rounded card matching the rest of the app.
     Title, message body, and up to two buttons (positive + optional negative). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_dialog_surface"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="26dp"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/dialogTitle"
        style="@style/TextSectionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp" />

    <TextView
        android:id="@+id/dialogMessage"
        style="@style/TextSmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="3dp"
        android:textColor="?attr/primaryColorTrans80" />

    <!-- Button row: negative (optional, hidden by default) + positive -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/dialogNegativeButton"
            style="@style/TextSmallBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:textAllCaps="true"
            android:textColor="?attr/primaryColorTrans80"
            android:visibility="gone" />

        <TextView
            android:id="@+id/dialogPositiveButton"
            style="@style/TextSmallBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:textAllCaps="true"
            android:textColor="?attr/primaryColor" />

    </LinearLayout>

</LinearLayout>
