<?xml version="1.0" encoding="utf-8"?>
<!-- Soft-limit cooldown dialog: a rounded glass card matching the rest of the app,
     with an hourglass, the app name, a short message and a large live countdown. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_dialog_surface"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="26dp"
    android:paddingBottom="16dp">

    <!-- Default: white hourglass. Severe blocks swap in @drawable/ic_block tinted
         @color/cooldownSevere from code (see MainActivity.showCooldownDialog). -->
    <ImageView
        android:id="@+id/cooldownIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginBottom="12dp"
        android:contentDescription="@string/limit_apps"
        android:src="@drawable/ic_hourglass"
        app:tint="?attr/primaryColor" />

    <TextView
        android:id="@+id/cooldownTitle"
        style="@style/TextSectionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        tools:text="Instagram" />

    <TextView
        android:id="@+id/cooldownMessage"
        style="@style/TextSmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="?attr/primaryColorTrans80"
        tools:text="You opened this recently. Take a breather." />

    <TextView
        android:id="@+id/cooldownTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.02"
        android:textColor="?attr/primaryColor"
        android:textSize="48sp"
        tools:text="04:59" />

    <TextView
        android:id="@+id/cooldownButton"
        style="@style/TextSmallBold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="18dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:text="@string/okay"
        android:textAllCaps="true"
        android:textColor="?attr/primaryColor" />
</LinearLayout>
