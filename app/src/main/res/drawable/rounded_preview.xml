<?xml version="1.0" encoding="utf-8"?>
<!-- Rounded base for the opacity-preview box; provides the outline used to clip
     the wallpaper thumbnail and the scrim to rounded corners. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="16dp" />
    <!-- Transparent base so 0% opacity looks exactly like the wallpaper (no tint). -->
    <solid android:color="@android:color/transparent" />
</shape>
