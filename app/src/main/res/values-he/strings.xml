    <string name="rate_us_message">היי, לא נציג לך הודעה זו בשנית.
        \n\nאם כיף לך להשתמש ב־BetterLauncher, האם נוכל בבקשה לקבל ממך דירוג של 5 כוכבים? זה יעזור לנו להתקדם בדירוג ויעשה לנו טוב על הלב. תודה מראש!</string>
    <string name="share_message">שלום, יש לנו משימה ענקית! אנחנו רוצים להגיע למיליון הורדות לפני סוף שנת 2023, ואנו זקוקים לעזרתך.
        \n\nהיית רוצה אולי לספר לחברים שלך על BetterLauncher? זה יכול לסייע לנו מאוד. תודה רבה!</string>
    <string name="keyboard_message">היי, יותר מהיר למצוא ולפתוח יישומים ב־BetterLauncher בעזרת ההקלדה. אולי בכל זאת היית רוצה להשאיר את ההגדרה הזאת ולתת לה עוד הזדמנות?
        \n\nThe choice is always yours.</string>
    <string name="wallpaper_message">BetterLauncher מציע טפטים חדשים ויפים מדי יום. תנו למסך הבית שלכם מראה חדש ורענן בכל יום, בחינם! רוצים לנסות?</string>
    <string name="accessibility_service_description">הרשאת הנגישות נחוצה להפעלת הנעילה בהקשה כפולה ולחצן הבית להצגת אפליקציות אחרונות. כל הנתונים שייאספו על ידי BetterLauncher דרך השירות הזה לא יועברו הלאה ממכשירך.</string>
    <string name="support_olauncher_for_free">אפשר לתמוך ב־BetterLauncher מבלי לשלם שקל, בעזרת שימוש בקישור ה־Amazon affiliate שלנו.</string>
    <string name="support_olauncher_message">על כל רכישה שתבוצע דרך הקישור שלנו אנחנו נקבל עמלה קטנה. נשמח אם תשמרו את הקישור ותשתמשו בו בקניות מהאינטרנט.\nתודה רבה!</string>
